# Desenvolvimento (acesso por IP na rede): use /api — proxy Vite → backend :8765
VITE_API_URL=/api

# Alternativa: API direta (só funciona se o browser estiver na mesma máquina do backend)
# VITE_API_URL=http://127.0.0.1:8765

# Acesso remoto sem proxy: backend precisa uvicorn --host 0.0.0.0
# VITE_API_URL=http://10.61.242.161:8765
