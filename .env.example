QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_TIMEOUT=20
QDRANT_COLLECTION=massive_pdf
QDRANT_HNSW_M=32
QDRANT_HNSW_EF_CONSTRUCT=200
QDRANT_HNSW_EF=96

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODELS=gemma4:26b,gemma4:e4b
OLLAMA_MODEL_DEFAULT=gemma4:26b
OLLAMA_MODEL=gemma4:26b
OLLAMA_TIMEOUT_DEFAULT=180
OLLAMA_TIMEOUT_HEAVY=600
# -1 ou 24h mantem o LLM na VRAM entre consultas (recomendado em servidor compartilhado).
OLLAMA_KEEP_ALIVE=20m
# false = nao chama ollama stop ao trocar de modelo (melhor p/ varios usuarios no mesmo Ollama).
OLLAMA_UNLOAD_ON_SWITCH=false
# true = descarrega Ollama antes da ingestao para liberar VRAM ao embedding (bge-m3 em CUDA).
INGEST_PAUSE_OLLAMA=true
# Embedding nas consultas: cpu evita disputa com Ollama/reranker na GPU.
QUERY_EMBED_DEVICE=cpu
# Habilita raciocinio interno (think) no Ollama para modelos compativeis (ex.: gemma4:26b).
OLLAMA_THINKING=true
# Teto aproximado de tokens do historico no chat (condensacao + contexto da conversa ativa).
CHAT_MEMORY_TOKEN_LIMIT=24000
# Resumo rolante: apos N rodadas, resume o historico antigo e mantem as ultimas CHAT_MEMORY_RECENT_TURNS.
CHAT_MEMORY_SUMMARIZE_ENABLED=true
CHAT_MEMORY_RECENT_TURNS=6
CHAT_MEMORY_SUMMARIZE_THRESHOLD_TURNS=8

# Contexto de pagina adjacente apos retrieval (melhora ancoragem em PDFs grandes).
PARENT_CONTEXT_PAGE_RADIUS=1
PARENT_CONTEXT_MAX_NODES=6
PARENT_CONTEXT_MAX_CHARS=6000

# Retry automatico quando poucos trechos recuperados em perguntas analiticas.
LOW_COV_FUSED_THRESHOLD=8
AUTO_RETRY_ON_LOW_COVERAGE=true

# Map-reduce analitico (panorama, cronologia, resumo do caso).
ANALYTICAL_MAP_REDUCE_ENABLED=true
ANALYTICAL_MAP_REDUCE_MIN_CHUNKS=12
ANALYTICAL_CHUNKS_PER_BATCH=6
ANALYTICAL_MAX_BATCHES=10

# Dimensao do vetor (bge-m3 = 1024). Usada ao criar colecao Qdrant antes da primeira ingest.
EMBEDDING_DIM=1024
EMBEDDING_MODEL_PATH=/home/paulopmgir/.cache/huggingface/hub/models--BAAI--bge-m3/snapshots/5617a9f61b028005a4858fdac845db406aefb181
RERANKER_MODEL_PATH=/home/paulopmgir/.cache/huggingface/hub/models--BAAI--bge-reranker-base/snapshots/2cfc18c9415c912f9d8155881c133215df768a70

CHUNK_SIZE=700
CHUNK_OVERLAP=120
# sentence_window = embedding no trecho + contexto amplo na resposta (recomendado p/ autos).
# chunks = apenas divisao por tamanho (legado). Apos mudar, reindexe com --reprocess-all.
INGEST_STRATEGY=sentence_window
# Vizinhos de cada trecho na janela expandida (indices de chunk na pagina).
SENTENCE_WINDOW_SIZE=5
# Base semantica legada (mantida para compatibilidade).
SIMILARITY_TOP_K=14
ENABLE_RERANKER=true
# cpu economiza VRAM para Ollama em GPUs 24GB (ex.: 26B + thinking). cuda, gpu ou auto.
RERANKER_DEVICE=cpu
RERANKER_TOP_N=10
RERANKER_CANDIDATE_K=22
INGEST_BATCH_FILES=2
INGEST_CHECKPOINT=.ingest_checkpoint.json
LEXICAL_DB_PATH=.lexical_index.db
PROJECTS_REGISTRY_PATH=data/projects_registry.json
DATA_DIR=data
AUTH_DATA_DIR=data/auth
PDF_EXTREME_AI_ROOT=/home/labfaces/pdf_extreme_ai

# Planejador: auto seleciona perfil por pergunta.
PLANNER_MODE=auto
RETRIEVAL_PROFILE_DEFAULT=preciso

# Perfil rapido (triagem)
PROFILE_RAPIDO_SEMANTIC_TOP_K=8
PROFILE_RAPIDO_LEXICAL_TOP_K=10
PROFILE_RAPIDO_RERANKER_CANDIDATE_K=16
PROFILE_RAPIDO_RERANKER_TOP_N=6
PROFILE_RAPIDO_LEXICAL_WEIGHT=0.30
PROFILE_RAPIDO_SEMANTIC_WEIGHT=0.70

# Perfil preciso (padrao recomendado). Orçamento RAG orientativo ~40-60k tokens no prompt.
# Se fused baixo na telemetria, suba gradualmente SEMANTIC_TOP_K e RERANKER_TOP_N (ex. 14->18, 10->12).
PROFILE_PRECISO_SEMANTIC_TOP_K=14
PROFILE_PRECISO_LEXICAL_TOP_K=16
PROFILE_PRECISO_RERANKER_CANDIDATE_K=28
PROFILE_PRECISO_RERANKER_TOP_N=10
PROFILE_PRECISO_LEXICAL_WEIGHT=0.45
PROFILE_PRECISO_SEMANTIC_WEIGHT=0.55

# Perfil pericial (exaustivo; mais lento, mais contexto documental)
PROFILE_PERICIAL_SEMANTIC_TOP_K=24
PROFILE_PERICIAL_LEXICAL_TOP_K=40
PROFILE_PERICIAL_RERANKER_CANDIDATE_K=48
PROFILE_PERICIAL_RERANKER_TOP_N=16
PROFILE_PERICIAL_LEXICAL_WEIGHT=0.60
PROFILE_PERICIAL_SEMANTIC_WEIGHT=0.40

# UI de ingestao (sidebar)
UI_INGEST_MAX_FILES=12
UI_INGEST_MAX_FILE_MB=512
INGEST_QUALITY_WARN_THRESHOLD=0.35

# Modo auditoria / varredura lexical
EXHAUSTIVE_BATCH_SIZE=500
EXHAUSTIVE_MAX_HITS=2000
AUDIT_MAP_REDUCE_THRESHOLD=25
AUDIT_PAGES_PER_BATCH=12

# OCR condicional (Fase 3; requer tesseract + pytesseract + Pillow)
ENABLE_OCR=false
OCR_QUALITY_THRESHOLD=0.35

TORCH_NUM_THREADS=32
# Com RERANKER_DEVICE=cpu, pode subir ate ~nucleos fisicos (ex. 48) para acelerar o cross-encoder.
TORCH_NUM_INTEROP_THREADS=8
